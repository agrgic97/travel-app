{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["@nativescript/types"],
    "paths": {
      "~/*": ["app/*"]
    }
  },
  "include": ["app/**/*.ts", "app/**/*.vue", "app/env.d.ts"]
}
